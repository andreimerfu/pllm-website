---
interface NavItem {
  label: string;
  href: string;
  external?: boolean;
}

interface PlatformItem {
  label: string;
  href: string;
  icon: string;
  description: string;
  accent: "brand" | "accent";
}

const platformItems: PlatformItem[] = [
  {
    label: "MCP Gateway",
    href: "/platform/mcp-gateway",
    icon: "solar:server-square-bold-duotone",
    description: "Registry, lifecycle & per-tool policy",
    accent: "brand",
  },
  {
    label: "Registry",
    href: "/platform/registry",
    icon: "solar:widget-bold-duotone",
    description: "Agents, skills & prompts as artifacts",
    accent: "accent",
  },
  {
    label: "Governance",
    href: "/platform/governance",
    icon: "solar:shield-keyhole-bold-duotone",
    description: "AD-group policies & audit",
    accent: "brand",
  },
  {
    label: "Guardrails",
    href: "/platform/guardrails",
    icon: "solar:shield-check-bold-duotone",
    description: "Pre / post / during / logging filters",
    accent: "accent",
  },
  {
    label: "Routing",
    href: "/platform/routing",
    icon: "solar:routing-2-bold-duotone",
    description: "Latency-aware routing & failover",
    accent: "brand",
  },
];

const topLevelItems: NavItem[] = [
  { label: "Roadmap", href: "/roadmap" },
  { label: "Changelog", href: "https://github.com/andreimerfu/pllm/releases", external: true },
];

const CALENDLY_URL = "https://calendly.com/andrei-amgital/introduction-scuto-ai";
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 transition-colors duration-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center space-x-2">
          <img src="/robot.png" alt="pLLM" class="w-8 h-8 rounded-lg" />
          <span class="text-xl font-bold text-slate-900 dark:text-white transition-colors duration-200">pLLM</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex lg:items-center lg:gap-1 lg:ml-10">
        <!-- Platform dropdown -->
        <div
          id="platform-dropdown"
          class="relative"
        >
          <button
            type="button"
            id="platform-trigger"
            class="inline-flex items-center gap-1.5 text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200"
            aria-expanded="false"
            aria-haspopup="true"
            aria-controls="platform-menu"
          >
            Platform
            <iconify-icon
              id="platform-chevron"
              icon="solar:alt-arrow-down-bold-duotone"
              width="14"
              height="14"
              class="transition-transform duration-200"
            ></iconify-icon>
          </button>

          <!-- Dropdown panel -->
          <div
            id="platform-menu"
            class="invisible opacity-0 absolute left-0 top-full mt-2 w-[540px] rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-xl shadow-slate-900/10 dark:shadow-black/50 origin-top-left transition-all duration-200 translate-y-1"
            role="menu"
          >
            <div class="p-3 grid grid-cols-2 gap-1">
              {platformItems.map((item) => (
                <a
                  href={item.href}
                  class="group flex items-start gap-3 rounded-lg px-3 py-3 hover:bg-slate-50 dark:hover:bg-slate-800/70 transition-colors"
                  role="menuitem"
                >
                  <div class={`w-9 h-9 rounded-md ${item.accent === "brand" ? "bg-brand-500/10 text-brand-600 dark:text-brand-400" : "bg-accent-500/10 text-accent-600 dark:text-accent-400"} flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform`}>
                    <iconify-icon icon={item.icon} width="18" height="18"></iconify-icon>
                  </div>
                  <div class="min-w-0">
                    <div class="text-sm font-semibold text-slate-900 dark:text-white leading-tight">
                      {item.label}
                    </div>
                    <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 leading-snug">
                      {item.description}
                    </div>
                  </div>
                </a>
              ))}

              <!-- Browse all tile -->
              <a
                href="/#platform"
                class="group flex items-center gap-3 rounded-lg px-3 py-3 border border-dashed border-slate-200 dark:border-slate-700 hover:border-brand-500/50 dark:hover:border-brand-400/50 transition-colors"
                role="menuitem"
              >
                <div class="w-9 h-9 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 flex items-center justify-center flex-shrink-0 group-hover:bg-brand-500/15 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                  <iconify-icon icon="solar:layers-minimalistic-bold-duotone" width="18" height="18"></iconify-icon>
                </div>
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-slate-900 dark:text-white leading-tight flex items-center gap-1">
                    All pillars
                    <iconify-icon icon="solar:arrow-right-bold-duotone" width="12" height="12" class="text-slate-400 group-hover:text-brand-500 group-hover:translate-x-0.5 transition-all"></iconify-icon>
                  </div>
                  <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 leading-snug">
                    Overview of the 5 primitives
                  </div>
                </div>
              </a>
            </div>

            <!-- Dropdown footer -->
            <div class="border-t border-slate-200 dark:border-slate-800 px-4 py-2.5 flex items-center justify-between text-xs font-mono text-slate-500 dark:text-slate-400">
              <span class="flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                v2026 · open source
              </span>
              <a
                href="https://github.com/andreimerfu/pllm"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-slate-900 dark:hover:text-white flex items-center gap-1 transition-colors"
              >
                <iconify-icon icon="mdi:github" width="12" height="12"></iconify-icon>
                GitHub
              </a>
            </div>
          </div>
        </div>

        <!-- Flat top-level items -->
        {topLevelItems.map((item) => (
          <a
            href={item.href}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noopener noreferrer" : undefined}
            class="inline-flex items-center gap-1 text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200"
          >
            {item.label}
            {item.external && (
              <iconify-icon icon="solar:arrow-right-up-linear" width="12" height="12" class="text-slate-400 dark:text-slate-500"></iconify-icon>
            )}
          </a>
        ))}
      </div>

      <!-- Right side: GitHub, Theme Toggle, Book demo, CTA -->
      <div class="hidden lg:flex items-center space-x-2">
        <a
          href="https://github.com/andreimerfu/pllm"
          target="_blank"
          rel="noopener noreferrer"
          class="w-9 h-9 rounded-lg flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors duration-200"
          aria-label="GitHub"
        >
          <iconify-icon icon="mdi:github" width="22" height="22"></iconify-icon>
        </a>
        <button
          id="theme-toggle"
          class="w-9 h-9 rounded-lg flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors duration-200"
          aria-label="Toggle theme"
        >
          <iconify-icon id="sun-icon" icon="solar:sun-bold-duotone" width="20" height="20" class="hidden"></iconify-icon>
          <iconify-icon id="moon-icon" icon="solar:moon-bold-duotone" width="20" height="20" class="hidden"></iconify-icon>
        </button>

        <!-- Divider -->
        <span class="h-5 w-px bg-slate-200 dark:bg-slate-700 mx-1"></span>

        <!-- Book a demo (ghost) -->
        <a
          href={CALENDLY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-200 border border-slate-200 dark:border-slate-700 hover:border-brand-500/60 dark:hover:border-brand-400/60 hover:text-brand-600 dark:hover:text-brand-400 transition-colors duration-200"
        >
          <iconify-icon icon="solar:calendar-date-bold-duotone" width="14" height="14"></iconify-icon>
          Book a demo
        </a>

        <!-- Get Started (primary) -->
        <a
          href="/#quick-start"
          class="bg-brand-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-brand-700 transition-colors duration-200"
        >
          Get Started
        </a>
      </div>

      <!-- Mobile: GitHub, Theme Toggle, Hamburger -->
      <div class="lg:hidden flex items-center space-x-1">
        <a
          href="https://github.com/andreimerfu/pllm"
          target="_blank"
          rel="noopener noreferrer"
          class="w-9 h-9 rounded-lg flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors duration-200"
          aria-label="GitHub"
        >
          <iconify-icon icon="mdi:github" width="22" height="22"></iconify-icon>
        </a>
        <button
          id="theme-toggle-mobile"
          class="w-9 h-9 rounded-lg flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors duration-200"
          aria-label="Toggle theme"
        >
          <iconify-icon id="sun-icon-mobile" icon="solar:sun-bold-duotone" width="20" height="20" class="hidden"></iconify-icon>
          <iconify-icon id="moon-icon-mobile" icon="solar:moon-bold-duotone" width="20" height="20" class="hidden"></iconify-icon>
        </button>
        <button
          type="button"
          id="mobile-menu-button"
          class="w-9 h-9 rounded-lg flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors duration-200"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <iconify-icon icon="solar:hamburger-menu-linear" width="22" height="22"></iconify-icon>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="lg:hidden hidden" id="mobile-menu">
    <div class="px-4 pt-3 pb-4 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 transition-colors duration-200">
      <!-- Platform section -->
      <div class="mb-4">
        <div class="text-[10px] font-mono tracking-wider uppercase text-slate-500 dark:text-slate-400 px-2 mb-2">
          Platform
        </div>
        <div class="space-y-1">
          {platformItems.map((item) => (
            <a
              href={item.href}
              class="flex items-start gap-3 px-2 py-2.5 rounded-md hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
            >
              <div class={`w-8 h-8 rounded-md ${item.accent === "brand" ? "bg-brand-500/10 text-brand-600 dark:text-brand-400" : "bg-accent-500/10 text-accent-600 dark:text-accent-400"} flex items-center justify-center flex-shrink-0`}>
                <iconify-icon icon={item.icon} width="16" height="16"></iconify-icon>
              </div>
              <div class="min-w-0">
                <div class="text-sm font-semibold text-slate-900 dark:text-white leading-tight">
                  {item.label}
                </div>
                <div class="text-xs text-slate-500 dark:text-slate-400 leading-snug">
                  {item.description}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Divider -->
      <div class="border-t border-slate-200 dark:border-slate-800 mb-3"></div>

      <!-- Top-level items -->
      <div class="space-y-1 mb-3">
        {topLevelItems.map((item) => (
          <a
            href={item.href}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noopener noreferrer" : undefined}
            class="flex items-center gap-1.5 px-3 py-2 rounded-md text-sm font-medium text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
          >
            {item.label}
            {item.external && (
              <iconify-icon icon="solar:arrow-right-up-linear" width="11" height="11" class="text-slate-400 dark:text-slate-500"></iconify-icon>
            )}
          </a>
        ))}
      </div>

      <!-- CTAs -->
      <div class="space-y-2">
        <a
          href="/#quick-start"
          class="block w-full bg-brand-600 text-white text-center px-6 py-2.5 rounded-lg font-medium hover:bg-brand-700 transition-colors"
        >
          Get Started
        </a>
        <a
          href={CALENDLY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full inline-flex items-center justify-center gap-2 px-6 py-2.5 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-200 border border-slate-200 dark:border-slate-700 hover:border-brand-500/60 dark:hover:border-brand-400/60 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
        >
          <iconify-icon icon="solar:calendar-date-bold-duotone" width="16" height="16"></iconify-icon>
          Book a demo
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // ─── Mobile menu ───
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
      });
    }

    // ─── Platform dropdown ───
    const dropdown = document.getElementById("platform-dropdown");
    const trigger = document.getElementById("platform-trigger");
    const menu = document.getElementById("platform-menu");
    const chevron = document.getElementById("platform-chevron");

    if (dropdown && trigger && menu) {
      let isOpen = false;
      let hoverTimer: number | undefined;

      const open = () => {
        if (isOpen) return;
        isOpen = true;
        menu.classList.remove("invisible", "opacity-0", "translate-y-1");
        menu.classList.add("translate-y-0");
        trigger.setAttribute("aria-expanded", "true");
        chevron?.classList.add("rotate-180");
      };

      const close = () => {
        if (!isOpen) return;
        isOpen = false;
        menu.classList.add("invisible", "opacity-0", "translate-y-1");
        menu.classList.remove("translate-y-0");
        trigger.setAttribute("aria-expanded", "false");
        chevron?.classList.remove("rotate-180");
      };

      const toggle = () => (isOpen ? close() : open());

      // Click toggles (accessible)
      trigger.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        toggle();
      });

      // Hover opens with small delay (desktop feel)
      dropdown.addEventListener("mouseenter", () => {
        window.clearTimeout(hoverTimer);
        hoverTimer = window.setTimeout(open, 80);
      });
      dropdown.addEventListener("mouseleave", () => {
        window.clearTimeout(hoverTimer);
        hoverTimer = window.setTimeout(close, 150);
      });

      // Click outside closes
      document.addEventListener("click", (e) => {
        if (!isOpen) return;
        if (!dropdown.contains(e.target as Node)) close();
      });

      // ESC closes
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && isOpen) {
          close();
          trigger.focus();
        }
      });
    }

    // ─── Theme toggle ───
    const updateIcons = () => {
      const isDark = document.documentElement.classList.contains("dark");
      const pairs = [
        ["sun-icon", "moon-icon"],
        ["sun-icon-mobile", "moon-icon-mobile"],
      ];
      for (const [sunId, moonId] of pairs) {
        const sun = document.getElementById(sunId);
        const moon = document.getElementById(moonId);
        if (sun) sun.classList.toggle("hidden", !isDark);
        if (moon) moon.classList.toggle("hidden", isDark);
      }
    };

    const toggleTheme = () => {
      const isDark = document.documentElement.classList.contains("dark");
      document.documentElement.classList.toggle("dark", !isDark);
      localStorage.setItem("theme", isDark ? "light" : "dark");
      updateIcons();
    };

    updateIcons();

    const toggleBtn = document.getElementById("theme-toggle");
    const toggleMobile = document.getElementById("theme-toggle-mobile");
    if (toggleBtn) toggleBtn.addEventListener("click", toggleTheme);
    if (toggleMobile) toggleMobile.addEventListener("click", toggleTheme);
  });
</script>
