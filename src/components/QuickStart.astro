---
import QuickStartTabs from "./QuickStartTabs.tsx";
---

<section id="quick-start" class="section bg-white dark:bg-slate-900 transition-colors duration-200">
  <div class="container-page">
    <!-- Section header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
      <div>
        <div class="inline-flex items-center gap-2 badge-brand text-sm font-semibold mb-4">
          <iconify-icon icon="solar:bolt-circle-bold-duotone" width="16" height="16"></iconify-icon>
          Quick Start
        </div>
        <h2 class="text-section-sm sm:text-section font-bold text-slate-900 dark:text-white tracking-tight">
          Running in two steps.
        </h2>
      </div>
      <p class="text-slate-600 dark:text-slate-400 max-w-md font-mono text-sm">
        $ deploy → $ point your SDK → ship
      </p>
    </div>

    <QuickStartTabs client:load />

    <!-- Closing CTAs -->
    <div class="mt-12 flex flex-col sm:flex-row gap-3 justify-center items-center">
      <a
        href="https://github.com/andreimerfu/pllm"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary flex items-center"
      >
        <iconify-icon icon="mdi:github" width="18" height="18" class="mr-2"></iconify-icon>
        Source on GitHub
      </a>
      <a
        href="https://github.com/andreimerfu/pllm/tree/main/docs"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary flex items-center"
      >
        <iconify-icon icon="solar:book-bookmark-bold-duotone" width="18" height="18" class="mr-2"></iconify-icon>
        Full documentation
      </a>
    </div>
  </div>
</section>
