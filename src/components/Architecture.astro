---
import InteractiveFlowDiagram from "./InteractiveFlowDiagram.tsx";
import ArchitectureDiagram from "./ArchitectureDiagram.tsx";
---

<section
    id="architecture"
    class="section bg-slate-50 dark:bg-slate-900 transition-colors duration-200"
>
    <div class="container-page">
        <!-- Section header -->
        <div class="section-header">
            <div class="inline-flex items-center gap-2 badge-brand text-sm font-semibold mb-4">
                <iconify-icon icon="solar:layers-bold-duotone" width="16" height="16"></iconify-icon>
                Under the Hood
            </div>
            <h2 class="section-title">
                A boring, fast, single binary.
            </h2>
            <p class="section-description">
                pLLM is one Go service — no sidecars, no Python runtime, no surprise dependencies.
                Boring infrastructure so your AI platform can stop being the interesting thing.
            </p>
        </div>

        <!-- Architecture diagram (has embedded live metrics) -->
        <div class="mb-16">
            <ArchitectureDiagram client:load />
        </div>

        <!-- Request flow — full width -->
        <div class="card p-6 sm:p-8">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
                <div>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Request flow</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400">
                        Auth → policy → router → guardrails → provider. Toggle a simulation mode to see failover in action.
                    </p>
                </div>
                <span class="text-xs font-mono text-slate-500 dark:text-slate-400 whitespace-nowrap">interactive</span>
            </div>
            <InteractiveFlowDiagram client:load />
        </div>
    </div>
</section>
