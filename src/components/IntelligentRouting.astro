---
import CodeBlock from './CodeBlock.tsx';
import '../styles/prism.css';

const routeConfigExample = `# A route named "smart" — your app just calls model: "smart".
# pLLM picks the best backend automatically.

POST /api/admin/routes
{
  "name": "Smart",
  "slug": "smart",
  "strategy": "least-latency",
  "models": [
    { "model_name": "gpt-5",          "weight": 60, "priority": 100 },
    { "model_name": "claude-4.6",     "weight": 30, "priority":  80 },
    { "model_name": "gemini-2.5-pro", "weight": 10, "priority":  60 }
  ],
  "fallback_models": ["gpt-4o-mini", "claude-haiku"]
}`;

const appUsageExample = `from openai import OpenAI

client = OpenAI(
    base_url="https://pllm.company.com/v1",
    api_key="sk-..."
)

# Call the route slug — not a specific model.
# pLLM picks the best backend in real-time.
response = client.chat.completions.create(
    model="smart",                        # pLLM route
    messages=[{"role": "user", "content": "Analyze this data"}],
    stream=True,
)

# If gpt-5 is slow      → routes to claude-4.6
# If claude is down     → circuit opens, fails over to gemini-2.5
# If all primaries fail → fallback chain (gpt-4o-mini, claude-haiku)
# Your app never knows. Zero code changes.`;

const scoreboard = [
  { value: "12.4M", label: "requests routed", sub: "last 30d", icon: "solar:routing-2-bold-duotone", accent: "brand" },
  { value: "0.82ms", label: "route-decision p95", sub: "gateway overhead", icon: "solar:bolt-circle-bold-duotone", accent: "brand" },
  { value: "3.2k", label: "failovers triggered", sub: "silent recovery", icon: "solar:shield-warning-bold-duotone", accent: "amber" },
  { value: "99.8%", label: "auto-recovery", sub: "no human paged", icon: "solar:shield-check-bold-duotone", accent: "emerald" },
  { value: "29%", label: "cost savings", sub: "vs single-provider", icon: "solar:wallet-money-bold-duotone", accent: "brand" },
];

const accentMap: Record<string, { bg: string; text: string }> = {
  brand: { bg: "bg-brand-500/10", text: "text-brand-600 dark:text-brand-400" },
  amber: { bg: "bg-amber-500/10", text: "text-amber-600 dark:text-amber-400" },
  emerald: { bg: "bg-emerald-500/10", text: "text-emerald-600 dark:text-emerald-400" },
};

const candidates = [
  {
    name: "gpt-5",
    provider: "openai",
    icon: "logos:openai-icon",
    p95: "42ms",
    errorRate: "0.01%",
    weight: 60,
    winner: true,
  },
  {
    name: "claude-4.6-sonnet",
    provider: "anthropic",
    icon: "logos:anthropic-icon",
    p95: "58ms",
    errorRate: "0.02%",
    weight: 30,
    winner: false,
  },
  {
    name: "gemini-2.5-pro",
    provider: "google",
    icon: "logos:google-cloud",
    p95: "71ms",
    errorRate: "0.08%",
    weight: 10,
    winner: false,
  },
];

const strategyMatrix = [
  {
    slug: "least-latency",
    name: "Least Latency",
    icon: "solar:bolt-circle-bold-duotone",
    picks: "Fastest p95 across healthy nodes",
    state: "Distributed EMA via Redis",
    bestFor: "Latency-sensitive apps · chat UIs · real-time agents",
  },
  {
    slug: "weighted-round-robin",
    name: "Weighted RR",
    icon: "solar:sort-by-time-bold-duotone",
    picks: "Smooth proportional rotation",
    state: "In-memory counters",
    bestFor: "Capacity-based distribution · multi-deployment setups",
  },
  {
    slug: "priority",
    name: "Priority",
    icon: "solar:arrow-to-top-right-bold-duotone",
    picks: "Highest-priority healthy backend",
    state: "Static ordering",
    bestFor: "Cost tiers · preferred provider · failover chains",
  },
  {
    slug: "random",
    name: "Random",
    icon: "solar:shuffle-bold-duotone",
    picks: "Uniform random across healthy",
    state: "Stateless",
    bestFor: "All-equal providers · stateless gateway nodes",
  },
];

const failoverLayers = [
  { level: "1", title: "Instance retry", description: "If an instance fails, pLLM tries another instance of the same model with 1.5× increasing timeouts.", color: "bg-brand-500" },
  { level: "2", title: "Model failover", description: "If all instances of a model fail, the route's strategy picks the next model in its list.", color: "bg-amber-500" },
  { level: "3", title: "Fallback chain", description: "If every model in the route is exhausted, pLLM walks the fallback_models chain as a last resort.", color: "bg-red-500" },
];
---

<section id="routing" class="section bg-white dark:bg-slate-900 transition-colors duration-200">
  <div class="container-page">
    <!-- Header -->
    <div class="section-header">
      <div class="inline-flex items-center gap-2 badge-brand text-sm font-semibold mb-4">
        <iconify-icon icon="solar:routing-2-bold-duotone" width="16" height="16"></iconify-icon>
        Routing &amp; Resilience
      </div>
      <h2 class="section-title">
        Your app calls "smart". pLLM picks the model.
      </h2>
      <p class="section-description">
        One route slug, many providers. Real-time latency-aware selection, silent failover, and self-healing
        circuit breakers — so outages, spikes, and cost tiers are a config change, not a deploy.
      </p>
    </div>

    <!-- Scoreboard -->
    <div class="mb-16 rounded-2xl border border-slate-200 dark:border-slate-800 bg-gradient-to-br from-slate-50 to-white dark:from-slate-900 dark:to-slate-950 overflow-hidden">
      <div class="flex items-center justify-between px-5 py-3 border-b border-slate-200 dark:border-slate-800">
        <div class="flex items-center gap-2 text-xs font-mono tracking-wider uppercase text-slate-500 dark:text-slate-400">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
          Live · acme-corp/production
        </div>
        <div class="text-xs font-mono text-slate-500 dark:text-slate-400">last 30d</div>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-5 divide-x divide-y lg:divide-y-0 divide-slate-200 dark:divide-slate-800">
        {scoreboard.map((s) => {
          const a = accentMap[s.accent];
          return (
            <div class="p-5 flex items-start gap-3">
              <div class={`w-9 h-9 rounded-md ${a.bg} flex items-center justify-center flex-shrink-0`}>
                <iconify-icon icon={s.icon} width="18" height="18" class={a.text}></iconify-icon>
              </div>
              <div class="min-w-0">
                <div class="text-2xl font-bold text-slate-900 dark:text-white leading-none mb-1 tabular-nums">{s.value}</div>
                <div class="text-xs font-medium text-slate-700 dark:text-slate-300 leading-tight">{s.label}</div>
                <div class="text-[10px] font-mono tracking-wider uppercase text-slate-500 dark:text-slate-400 mt-0.5">{s.sub}</div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- THE DECISION — live route panel -->
    <div class="mb-20">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-8">
        <div>
          <div class="text-xs font-mono tracking-wider uppercase text-brand-600 dark:text-brand-400 mb-2">The decision</div>
          <h3 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">
            What happens when a request hits "smart".
          </h3>
        </div>
      </div>

      <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-slate-950 overflow-hidden">
        <!-- Terminal chrome -->
        <div class="flex items-center justify-between bg-slate-900 border-b border-slate-800 px-4 py-2.5">
          <div class="flex items-center gap-2">
            <div class="flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-amber-400/70"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-emerald-400/70"></span>
            </div>
            <span class="ml-3 text-xs font-mono text-slate-400">pllm-router · live</span>
          </div>
          <div class="flex items-center gap-2 text-xs font-mono text-slate-500">
            <span class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
              strategy: least-latency
            </span>
          </div>
        </div>

        <div class="p-5 sm:p-7 font-mono text-sm leading-relaxed space-y-5">
          <!-- Step 1: incoming -->
          <div>
            <div class="flex items-center gap-2 mb-2 text-[10px] font-mono tracking-wider uppercase text-slate-500">
              <span class="tabular-nums text-slate-600">01</span>
              <span>incoming</span>
            </div>
            <div class="rounded-md border border-slate-800 bg-slate-900/50 px-3 py-2.5 text-slate-300">
              <span class="text-slate-500">POST</span>{" "}
              <span class="text-white">/v1/chat/completions</span>{" "}
              <span class="text-slate-500">→</span>{" "}
              <span class="text-brand-400">model: </span>
              <span class="text-amber-300">"smart"</span>
            </div>
          </div>

          <!-- Step 2: candidates -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2 text-[10px] font-mono tracking-wider uppercase text-slate-500">
                <span class="tabular-nums text-slate-600">02</span>
                <span>resolve route · evaluate candidates</span>
              </div>
              <span class="text-[10px] font-mono text-slate-500">
                3 healthy · 0 degraded · 0 failed
              </span>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-900/50 overflow-hidden">
              <div class="grid grid-cols-[auto_1fr_auto_auto_auto] gap-3 px-3 py-2 border-b border-slate-800 text-[10px] font-mono tracking-wider uppercase text-slate-500">
                <div class="w-4"></div>
                <div>model</div>
                <div>p95</div>
                <div>errors</div>
                <div>weight</div>
              </div>
              {candidates.map((c) => (
                <div class={`grid grid-cols-[auto_1fr_auto_auto_auto] gap-3 items-center px-3 py-2.5 ${c.winner ? "bg-brand-500/[0.08] border-l-2 border-brand-500" : "border-l-2 border-transparent"}`}>
                  <div class="w-4 flex items-center justify-center">
                    {c.winner ? (
                      <span class="w-2 h-2 rounded-full bg-brand-400 shadow-[0_0_8px_rgba(45,212,191,0.8)]"></span>
                    ) : (
                      <span class="w-2 h-2 rounded-full border border-slate-600"></span>
                    )}
                  </div>
                  <div class="flex items-center gap-2 min-w-0">
                    <div class="w-5 h-5 rounded bg-white flex items-center justify-center flex-shrink-0 border border-slate-700">
                      <iconify-icon icon={c.icon} width="12" height="12"></iconify-icon>
                    </div>
                    <span class={c.winner ? "text-white font-bold" : "text-slate-300"}>{c.name}</span>
                    <span class="text-slate-500 text-xs">·</span>
                    <span class="text-slate-500 text-xs truncate">{c.provider}</span>
                  </div>
                  <span class={`tabular-nums ${c.winner ? "text-brand-300" : "text-slate-400"}`}>{c.p95}</span>
                  <span class="tabular-nums text-slate-500 text-xs">{c.errorRate}</span>
                  <span class="tabular-nums text-slate-500 text-xs">{c.weight}%</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Step 3: winner -->
          <div>
            <div class="flex items-center gap-2 mb-2 text-[10px] font-mono tracking-wider uppercase text-slate-500">
              <span class="tabular-nums text-slate-600">03</span>
              <span>winner · dispatch</span>
            </div>
            <div class="rounded-md border border-brand-500/40 bg-brand-500/[0.08] px-3 py-2.5 flex flex-wrap items-center gap-x-4 gap-y-1">
              <span class="text-slate-400">→</span>
              <span class="text-brand-300 font-bold">gpt-5</span>
              <span class="text-slate-500">@</span>
              <span class="text-white">openai / us-east-2 / instance #3</span>
              <span class="ml-auto text-slate-500 text-xs">decided in <span class="text-brand-300 tabular-nums">0.82ms</span></span>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div class="bg-slate-900 border-t border-slate-800 px-5 py-3 grid grid-cols-3 gap-2 text-center">
          <div>
            <div class="text-sm font-bold text-white tabular-nums">42ms</div>
            <div class="text-[9px] font-mono tracking-wider uppercase text-slate-500">winner p95</div>
          </div>
          <div class="border-x border-slate-800">
            <div class="text-sm font-bold text-white tabular-nums">&lt;1ms</div>
            <div class="text-[9px] font-mono tracking-wider uppercase text-slate-500">router overhead</div>
          </div>
          <div>
            <div class="text-sm font-bold text-white tabular-nums">0</div>
            <div class="text-[9px] font-mono tracking-wider uppercase text-slate-500">retry code in your app</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Strategy matrix -->
    <div class="mb-20">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
        <div>
          <div class="text-xs font-mono tracking-wider uppercase text-brand-600 dark:text-brand-400 mb-2">Decision guide</div>
          <h3 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">
            Which strategy fits your traffic?
          </h3>
          <p class="text-slate-600 dark:text-slate-400 mt-1">
            Each route picks a strategy. Strategies run at request time using real-time metrics, not static config.
          </p>
        </div>
      </div>

      <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
              <tr class="text-left text-xs font-mono tracking-wider uppercase text-slate-500 dark:text-slate-400">
                <th class="px-5 py-3 font-medium">Strategy</th>
                <th class="px-5 py-3 font-medium">How it picks</th>
                <th class="px-5 py-3 font-medium">State</th>
                <th class="px-5 py-3 font-medium">Best for</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              {strategyMatrix.map((s) => (
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/40 transition-colors">
                  <td class="px-5 py-4 whitespace-nowrap">
                    <div class="flex items-center gap-2.5">
                      <div class="w-7 h-7 rounded-md bg-brand-500/10 flex items-center justify-center flex-shrink-0">
                        <iconify-icon icon={s.icon} width="14" height="14" class="text-brand-600 dark:text-brand-400"></iconify-icon>
                      </div>
                      <div>
                        <div class="font-bold text-slate-900 dark:text-white">{s.name}</div>
                        <code class="text-[10px] font-mono text-slate-500 dark:text-slate-400">{s.slug}</code>
                      </div>
                    </div>
                  </td>
                  <td class="px-5 py-4 text-slate-600 dark:text-slate-300">{s.picks}</td>
                  <td class="px-5 py-4">
                    <span class="inline-flex font-mono text-xs px-2 py-0.5 rounded bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700">{s.state}</span>
                  </td>
                  <td class="px-5 py-4 text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{s.bestFor}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Configuration side-by-side -->
    <div class="mb-20">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
        <div>
          <div class="text-xs font-mono tracking-wider uppercase text-brand-600 dark:text-brand-400 mb-2">Configuration</div>
          <h3 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">
            Two steps. Admin API + standard SDK.
          </h3>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
        <!-- Define -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <div class="w-7 h-7 rounded-md bg-brand-500/15 text-brand-600 dark:text-brand-400 flex items-center justify-center">
              <iconify-icon icon="solar:settings-bold-duotone" width="14" height="14"></iconify-icon>
            </div>
            <h4 class="text-sm font-bold text-slate-900 dark:text-white">1. Define a route</h4>
            <span class="text-[10px] font-mono text-slate-500 dark:text-slate-400">admin API · no restart</span>
          </div>
          <CodeBlock code={routeConfigExample} language="javascript" client:load />
        </div>

        <!-- Use -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <div class="w-7 h-7 rounded-md bg-accent-500/15 text-accent-600 dark:text-accent-400 flex items-center justify-center">
              <iconify-icon icon="solar:play-circle-bold-duotone" width="14" height="14"></iconify-icon>
            </div>
            <h4 class="text-sm font-bold text-slate-900 dark:text-white">2. Use it in your app</h4>
            <span class="text-[10px] font-mono text-slate-500 dark:text-slate-400">OpenAI SDK · no change</span>
          </div>
          <CodeBlock code={appUsageExample} language="python" client:load />
        </div>
      </div>
    </div>

    <!-- Failover + circuit breaker -->
    <div>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
        <div>
          <div class="text-xs font-mono tracking-wider uppercase text-brand-600 dark:text-brand-400 mb-2">Resilience</div>
          <h3 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">
            When things break, your app doesn't.
          </h3>
          <p class="text-slate-600 dark:text-slate-400 mt-1">
            Three escalating layers of failover, plus a self-healing circuit breaker on every provider.
          </p>
        </div>
      </div>

      <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 sm:p-8 lg:p-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14">
          <!-- Failover layers -->
          <div>
            <div class="inline-flex items-center gap-2 text-xs font-mono tracking-wider uppercase text-brand-600 dark:text-brand-400 mb-3">
              <iconify-icon icon="solar:layers-minimalistic-bold-duotone" width="14" height="14"></iconify-icon>
              Failover ladder
            </div>
            <h4 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
              Three layers, in order.
            </h4>
            <div class="space-y-3">
              {failoverLayers.map((layer) => (
                <div class="flex items-start gap-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/40 p-4">
                  <div class={`w-9 h-9 rounded-md ${layer.color} flex items-center justify-center flex-shrink-0 text-white font-bold text-sm`}>
                    {layer.level}
                  </div>
                  <div class="min-w-0">
                    <h5 class="text-slate-900 dark:text-white font-bold mb-1">{layer.title}</h5>
                    <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{layer.description}</p>
                  </div>
                </div>
              ))}
            </div>
            <div class="mt-4 flex items-start gap-3 rounded-lg border border-amber-500/30 bg-amber-500/[0.06] dark:bg-amber-500/[0.08] p-4">
              <iconify-icon icon="solar:bolt-circle-bold-duotone" width="18" height="18" class="text-amber-500 flex-shrink-0 mt-0.5"></iconify-icon>
              <p class="text-sm text-slate-700 dark:text-slate-300">
                Each retry uses <strong class="text-slate-900 dark:text-white">1.5× increasing timeout</strong>. Up to 10 failover hops with loop detection.
              </p>
            </div>
          </div>

          <!-- Circuit breaker -->
          <div>
            <div class="inline-flex items-center gap-2 text-xs font-mono tracking-wider uppercase text-brand-600 dark:text-brand-400 mb-3">
              <iconify-icon icon="solar:shield-warning-bold-duotone" width="14" height="14"></iconify-icon>
              Circuit breaker
            </div>
            <h4 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
              Self-healing, no paging.
            </h4>

            <div class="space-y-2">
              <div class="rounded-lg border border-emerald-500/30 bg-emerald-500/[0.04] dark:bg-emerald-500/[0.08] p-4">
                <div class="flex items-center justify-between gap-2.5 mb-1.5">
                  <div class="flex items-center gap-2.5">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    <h5 class="text-emerald-700 dark:text-emerald-400 font-bold text-sm tracking-wider">CLOSED · HEALTHY</h5>
                  </div>
                  <code class="text-[10px] font-mono text-slate-500 dark:text-slate-400">normal</code>
                </div>
                <p class="text-slate-600 dark:text-slate-400 text-xs leading-relaxed">All traffic flows. Failure counter active.</p>
              </div>

              <div class="flex items-center justify-center gap-2 text-xs font-mono text-slate-400 dark:text-slate-500 py-1">
                <span>3 consecutive failures</span>
                <iconify-icon icon="solar:alt-arrow-down-bold-duotone" width="12" height="12"></iconify-icon>
              </div>

              <div class="rounded-lg border border-red-500/30 bg-red-500/[0.04] dark:bg-red-500/[0.08] p-4">
                <div class="flex items-center justify-between gap-2.5 mb-1.5">
                  <div class="flex items-center gap-2.5">
                    <span class="w-2 h-2 rounded-full bg-red-500"></span>
                    <h5 class="text-red-600 dark:text-red-400 font-bold text-sm tracking-wider">OPEN · UNHEALTHY</h5>
                  </div>
                  <code class="text-[10px] font-mono text-slate-500 dark:text-slate-400">removed</code>
                </div>
                <p class="text-slate-600 dark:text-slate-400 text-xs leading-relaxed">Traffic blocked. Provider pulled from rotation. 30s cooldown.</p>
              </div>

              <div class="flex items-center justify-center gap-2 text-xs font-mono text-slate-400 dark:text-slate-500 py-1">
                <span>cooldown elapsed</span>
                <iconify-icon icon="solar:alt-arrow-down-bold-duotone" width="12" height="12"></iconify-icon>
              </div>

              <div class="rounded-lg border border-amber-500/30 bg-amber-500/[0.04] dark:bg-amber-500/[0.08] p-4">
                <div class="flex items-center justify-between gap-2.5 mb-1.5">
                  <div class="flex items-center gap-2.5">
                    <span class="w-2 h-2 rounded-full bg-amber-500"></span>
                    <h5 class="text-amber-600 dark:text-amber-400 font-bold text-sm tracking-wider">HALF-OPEN · TESTING</h5>
                  </div>
                  <code class="text-[10px] font-mono text-slate-500 dark:text-slate-400">probe</code>
                </div>
                <p class="text-slate-600 dark:text-slate-400 text-xs leading-relaxed">One probe request. Success → closed. Failure → open.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-8 pt-8 border-t border-slate-200 dark:border-slate-800">
          <div>
            <div class="text-3xl font-bold text-slate-900 dark:text-white tabular-nums">0</div>
            <div class="text-sm text-slate-500 dark:text-slate-400">Lines of retry code in your app</div>
          </div>
          <div class="sm:border-x sm:border-slate-200 sm:dark:border-slate-800 sm:px-6">
            <div class="text-3xl font-bold text-slate-900 dark:text-white tabular-nums">&lt;30s</div>
            <div class="text-sm text-slate-500 dark:text-slate-400">Automatic recovery window</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-slate-900 dark:text-white tabular-nums">10</div>
            <div class="text-sm text-slate-500 dark:text-slate-400">Max failover hops per request</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
